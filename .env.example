# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key — free tier available at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Supabase Postgres URI for LangGraph session checkpoints.
# If omitted, the app runs in stateless mode (no session persistence).
# Format: postgresql://postgres:[password]@[host]:5432/postgres
SUPABASE_DB_URI=

# Enable the internal MCP tool server (true | false)
USE_MCP=false

# LLM timeout overrides (seconds)
RITUAL_TIMEOUT_SECONDS=25
REFLECT_TIMEOUT_SECONDS=12
INTENTION_TIMEOUT_SECONDS=12
RETREAT_MATCH_TIMEOUT_SECONDS=25
